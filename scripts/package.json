{
  "name": "@workspace/scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "hello": "tsx ./src/hello.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "post-merge": "powershell -ExecutionPolicy Bypass -File ./post-merge.ps1",
    "first-time-setup": "powershell -ExecutionPolicy Bypass -File ./first-time-setup.ps1",
    "start-dev": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1",
    "start-dev:force": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1 -ForceRestart"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:"
  }
}
